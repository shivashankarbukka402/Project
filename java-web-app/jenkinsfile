pipeline {
  agent any
  tools {
    maven 'Maven3'
}

  environment {
    ECR_REPO = '302173659698.dkr.ecr.ap-south-1.amazonaws.com/my-app'
    SONAR_HOST_URL='http://13.233.232.204:9000'

  }
  stages {
    stage('Clone') {
      steps {
         git branch: 'main', url: 'https://github.com/shivashankarbukka402/Project.git'
           
      }
    }
    stage('Build') {
      steps {
        dir('java-web-app') {
          sh 'mvn clean package'
        }
      }
    }
    stage('SonarQube Analysis') {
      steps {
        dir('java-web-app') {
           withCredentials([string(credentialsId: 'SONAR_TOKEN', variable: 'SONAR_TOKEN')]){
             sh '''
                    sonar-scanner \
                      -Dsonar.projectKey=my-project \
                      -Dsonar.sources=. \
                      -Dsonar.host.url=http://<your-server-ip>:9000 \
                      -Dsonar.login=$SONAR_AUTH_TOKEN
                    '''
          }
        }
      }
    }
    stage('Docker Build & Push') {
      steps {
        script {
          sh '''
            aws ecr get-login-password --region ap-south-1 | docker login --username AWS --password-stdin 302173659698.dkr.ecr.ap-south-1.amazonaws.com
            docker build -t myapp .
            docker tag myapp:latest 302173659698.dkr.ecr.ap-south-1.amazonaws.com/my-app:latest
            docker push 302173659698.dkr.ecr.ap-south-1.amazonaws.com/my-app:latest
          '''
        }
      }
    }
    stage('Deploy to ECS') {
      steps {
        sh 'aws ecs update-service --cluster my-cluster --service my-service --force-new-deployment'
      }
    }
  }
}

